generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  image       String?
  email       String   @unique
  phoneNumber String?
  password    String
  role        String   @default("user")
  otp         String?
  otpExpires  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

model Service {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  kh_name       String
  icon          String
  description   String
  kh_description String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("services")
}

model Package {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  kh_name        String
  price          String
  description    String
  kh_description String
  features       String[]
  kh_features    String[]
  recommend      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("packages")
}

model TeamMember {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  kh_name        String?
  role           String
  kh_role        String?
  bio            String?
  kh_bio         String?
  image          String?
  portfolio_link String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("team_members")
}


model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  message   String
  status    String   @default("unread") // "unread", "read", "archived"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  content     String
  image       String
  link        String?
  category    String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model ProjectRequest {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String
  phoneNumber      String?
  businessName     String?
  businessType     String?
  websiteGoals     String?
  pagesNeeded      String?
  designPreference String?
  competitors      String?
  packageId        String?  @db.ObjectId
  status           String   @default("pending") // "pending", "reviewed", "in_progress", "completed", "cancelled"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("project_requests")
}
